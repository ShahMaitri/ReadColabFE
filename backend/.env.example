NODE_ENV=development
PORT=4000
API_PREFIX=/api
API_VERSION=v1
DATABASE_URL="file:./prisma/dev.db"
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:5177,http://127.0.0.1:5177

# ============================================
# AI Service Configuration
# ============================================

# AI Provider to use
# Options: github, openai, gemini, claude, ollama
# Default: github
AI_PROVIDER=github

# GitHub Models Provider (Default)
# Get your API key from GitHub (requires setup with GitHub Models)
# Leave empty to use mock responses
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_MODEL=gpt-4
# Optional endpoint override for GitHub Models (OpenAI-compatible)
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com/chat/completions

# OpenAI Provider
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Google Gemini Provider
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Anthropic Claude Provider
# Get your API key from https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# Ollama Provider (Local)
# URL to your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
